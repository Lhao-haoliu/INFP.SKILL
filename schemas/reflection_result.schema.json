{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "scene",
    "questions"
  ],
  "properties": {
    "scene": {
      "type": "string"
    },
    "questions": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
